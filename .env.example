# ── Ports ──
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ── Database ──
DATABASE_URL=sqlite:///./formcoach.db

# ── CORS: comma-separated list of allowed origins ──
# Set this to your iPhone's local IP if needed:  http://192.168.x.x:3000
CORS_ORIGINS=*

# ── API Keys ──
SECRET_KEY=change-me
