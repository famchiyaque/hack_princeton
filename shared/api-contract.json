{
  "info": {
    "title": "FormCoach API",
    "description": "Backend endpoints for exercise reference data and session history.",
    "version": "1.0.0"
  },
  "baseURL": "http://localhost:8000/api",
  "endpoints": {
    "healthCheck": {
      "method": "GET",
      "path": "/health",
      "response": { "status": "ok", "service": "formcoach" }
    },
    "getExercises": {
      "method": "GET",
      "path": "/exercises",
      "response": {
        "exercises": [
          {
            "id": "pushup",
            "name": "Push-Up",
            "phases": [
              {
                "name": "bottom",
                "referenceAngles": {
                  "elbowAngle": { "min": 70, "max": 100 },
                  "hipAngle":   { "min": 160, "max": 180 },
                  "spineAngle": { "min": 160, "max": 180 }
                }
              },
              {
                "name": "top",
                "referenceAngles": {
                  "elbowAngle": { "min": 155, "max": 180 },
                  "hipAngle":   { "min": 160, "max": 180 },
                  "spineAngle": { "min": 160, "max": 180 }
                }
              }
            ],
            "corrections": {
              "elbowAngle_high": "Go deeper",
              "elbowAngle_low":  "Fully extend your arms",
              "hipAngle_low":    "Keep your hips up",
              "spineAngle_low":  "Straighten your back"
            }
          }
        ]
      }
    },
    "getExercise": {
      "method": "GET",
      "path": "/exercises/:id",
      "response": {
        "id": "pushup",
        "name": "Push-Up",
        "phases": [],
        "corrections": {}
      }
    },
    "createSession": {
      "method": "POST",
      "path": "/sessions",
      "body": {
        "userId": "anonymous",
        "exercises": [
          {
            "exerciseId": "pushup",
            "reps": 10,
            "avgScore": 78.5,
            "duration": 45,
            "corrections": [{ "type": "elbowAngle_high", "count": 3 }]
          }
        ],
        "totalDuration": 120,
        "startedAt": "2026-04-18T10:00:00Z"
      },
      "response": {
        "id": "",
        "userId": "anonymous",
        "totalDuration": 120,
        "startedAt": "",
        "createdAt": "",
        "exercises": []
      }
    },
    "getSessions": {
      "method": "GET",
      "path": "/sessions",
      "query": ["userId", "limit", "offset"],
      "response": {
        "sessions": [],
        "total": 0
      }
    },
    "getSession": {
      "method": "GET",
      "path": "/sessions/:id",
      "response": {
        "id": "",
        "userId": "anonymous",
        "totalDuration": 0,
        "startedAt": "",
        "createdAt": "",
        "exercises": []
      }
    },
    "analyzeSession": {
      "method": "POST",
      "path": "/analysis",
      "note": "Stretch goal — requires ANTHROPIC_API_KEY in .env",
      "body": {
        "sessionId": "",
        "rawData": {}
      },
      "response": {
        "summary": "",
        "tips": []
      }
    }
  }
}
