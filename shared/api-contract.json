{
  "info": {
    "title": "Kinetic API",
    "description": "Backend endpoints for user profiles, exercise reference data, session history, and aggregated insights. All real-time form analysis runs on-device.",
    "version": "1.3.0"
  },
  "baseURL": "http://localhost:8000/api",
  "endpoints": {
    "healthCheck": {
      "method": "GET",
      "path": "/health",
      "response": { "status": "ok", "service": "kinetic" }
    },
    "getExercises": {
      "method": "GET",
      "path": "/exercises",
      "response": { "exercises": [] }
    },
    "upsertUser": {
      "method": "POST",
      "path": "/users",
      "body": {
        "id": "uuid-or-blank",
        "name": "Alex",
        "goals": ["athleticism"],
        "fitnessLevel": "beginner",
        "weightLbs": 175,
        "heightFeet": 5,
        "heightInches": 10,
        "age": 30,
        "gender": "prefer_not_to_say",
        "healthNotes": ["knee_pain"],
        "bodyGoals": ["stronger_core", "better_posture"]
      },
      "response": {
        "id": "", "name": "", "goals": [], "fitnessLevel": "",
        "weightLbs": 175, "heightFeet": 5, "heightInches": 10, "age": 30, "gender": "",
        "healthNotes": [], "bodyGoals": [], "createdAt": ""
      }
    },
    "getUser": {
      "method": "GET",
      "path": "/users/:id",
      "response": { "id": "", "name": "", "goals": [], "fitnessLevel": "", "weightLbs": 175, "heightFeet": 5, "heightInches": 10, "age": 30, "gender": "", "healthNotes": [], "bodyGoals": [], "createdAt": "" }
    },
    "createSession": {
      "method": "POST",
      "path": "/sessions",
      "body": {
        "userId": "",
        "exercises": [
          {
            "exerciseId": "squat",
            "reps": 10,
            "avgScore": 82.5,
            "duration": 90,
            "corrections": [{ "type": "kneeAngle", "count": 3 }]
          }
        ],
        "totalDuration": 180,
        "startedAt": "ISO8601"
      },
      "response": {
        "id": "", "userId": "", "totalDuration": 0, "startedAt": "", "createdAt": "", "exercises": []
      }
    },
    "getSessions": {
      "method": "GET",
      "path": "/sessions",
      "query": ["userId", "limit", "offset"],
      "response": { "sessions": [], "total": 0 }
    },
    "getSession": {
      "method": "GET",
      "path": "/sessions/:id",
      "response": {}
    },
    "getInsights": {
      "method": "GET",
      "path": "/insights/:userId",
      "note": "Deterministic aggregation across all of a user's stored sessions.",
      "response": {
        "totalSessions": 0,
        "totalReps": 0,
        "totalMinutes": 0,
        "overallAvgScore": 0.0,
        "streakDays": 0,
        "byExercise": [],
        "topCorrections": [],
        "last7DaysMinutes": [0, 0, 0, 0, 0, 0, 0]
      }
    }
  }
}
